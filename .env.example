DATABASE_URL="file:./dev.db"

# Optional: X/Twitter collection through Apify. Actor input varies by actor.
APIFY_TOKEN=""
APIFY_X_ACTOR="apidojo/tweet-scraper"
APIFY_X_INPUT_JSON="{\"searchTerms\":[\"AI OR LLM OR OpenAI OR Claude OR agent lang:en\"],\"maxItems\":30,\"sort\":\"Latest\"}"

# Optional: tune Reddit collection.
REDDIT_USER_AGENT="ai-signal-hub/0.1 by local"
REDDIT_SUBREDDITS="LocalLLaMA,MachineLearning,OpenAI,ArtificialInteligence,singularity"
